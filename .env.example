# SendGrid (alternative)
# SENDGRID_API_KEY=
# SENDGRID_INBOUND_WEBHOOK_SECRET=
# SENDGRID_FROM_EMAIL=

# Agent behavior
MAX_DOWNLOADS=10
DOWNLOAD_DIR=./downloads
OUTPUT_DIR=./output
UARB_BASE_URL=https://uarb.novascotia.ca/fmi/webd/UARB15

# Playwright
HEADLESS=true
PAGE_LOAD_TIMEOUT_MS=60000
ACTION_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=INFO
