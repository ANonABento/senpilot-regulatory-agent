# Email — Gmail via App Password (IMAP poll + SMTP send). See docs/EMAIL.md.
# Create a dedicated Gmail, enable 2-Step Verification, generate an App Password,
# and enable IMAP (Gmail settings -> Forwarding and POP/IMAP).
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
# Defaults below are correct for Gmail; override only if needed.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
MAILBOX=INBOX
POLL_INTERVAL_SEC=45

# LLM (optional — parsing/reply fall back to regex+template if unset)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Agent behavior
MAX_DOWNLOADS=10
DOWNLOAD_DIR=./downloads
OUTPUT_DIR=./output
UARB_BASE_URL=https://uarb.novascotia.ca/fmi/webd/UARB15

# Playwright
HEADLESS=true
PAGE_LOAD_TIMEOUT_MS=60000
ACTION_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=INFO
