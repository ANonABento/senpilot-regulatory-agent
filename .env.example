# LLM (email parsing + reply drafting)
OPENAI_API_KEY=
# or
ANTHROPIC_API_KEY=

# Email provider — choose one approach (see docs/EMAIL.md)
# Gmail API
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_ADDRESS=
